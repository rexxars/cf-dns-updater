{
  "name": "cf-dns-updater",
  "version": "3.0.4",
  "description": "Update a DNS record on CloudFlare with a new IP",
  "homepage": "https://github.com/rexxars/cf-dns-updater#readme",
  "bugs": {
    "url": "https://github.com/rexxars/cf-dns-updater/issues"
  },
  "license": "MIT",
  "author": "Espen Hovlandsdal <espen@hovlandsdal.com>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rexxars/cf-dns-updater.git"
  },
  "bin": {
    "cf-dns-updater": "./dist/cf-updater.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "get-it": "^9.0.1",
    "public-ip": "^8.0.0",
    "string-width": "^8.2.1",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@sanity/semantic-release-preset": "^6.0.0",
    "@types/node": "^26.0.0",
    "@types/update-notifier": "^6.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "semantic-release": "^25.0.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
